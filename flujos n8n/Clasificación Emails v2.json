    {
      "parameters": {
        "jsCode": "const agentResponse = $input.first().json;\nconst prevData = $node['Gmail Trigger'].json;\n\nlet aiAnswer = '';\nlet confidence = 0;\n\ntry {\n  const outputText = agentResponse.output || agentResponse.text || '';\n  const jsonMatch = outputText.match(/\\{[\\s\\S]*?\\}/);\n  if (jsonMatch) {\n    const parsed = JSON.parse(jsonMatch[0]);\n    aiAnswer = parsed;\n    confidence = 100;\n  }\n} catch(e) {\n  aiAnswer = { error: e.message };\n  confidence = 0;\n}\n\nreturn [{\n  json: {\n    ...aiAnswer,\n    confidence,\n    messageId: prevData.id,\n    subject: prevData.subject || prevData.Subject,\n    from: prevData.from?.text || prevData.From\n  }\n}];"
      },
