      "parameters": {
        "jsCode": "const items = $input.all();\nconst labelsResponse = items[0].json;\nconst calcData = $node['Calcular Día-Actividad'].json;\n\nconst targetLabel = calcData.labelName;\nconst messageId = calcData.messageId;\nconst labels = labelsResponse.labels || [];\n\nconst found = labels.find(l => l.name === targetLabel);\n\nreturn [{\n  json: {\n    labelId: found ? found.id : null,\n    labelExists: found ? true : false,\n    labelName: targetLabel,\n    messageId: messageId\n  }\n}];"
      },
