    {
      "parameters": {
        "jsCode": "// Actualizar el evento: mover guía de pendientes a confirmado\n// Leer estado actual del evento y actualizar\nconst data = $node[\"Consolidar Datos\"].json;\n\n// Nuevo título con guía confirmado\n// NOTA: En producción, leer el evento actual de Sheet para obtener\n// la lista completa de pendientes y actualizar correctamente\nconst guiaConfirmado = data.guiaCodigo;\n\nreturn [{\n  json: {\n    ...data,\n    nuevoGuiaConfirmado: guiaConfirmado,\n    mensajeExito: `✅ ${data.guiaNombre} ha confirmado para ${data.tourCode} el ${data.fecha}`\n  }\n}];"
      },
      "id": "96a5608a-ce92-4b6e-bf8e-86a0306c8228",
