    {
      "parameters": {
        "jsCode": "// Combinar datos de la confirmación + respuesta\nconst confData = $input.first().json;\nconst respData = $node[\"Parsear Respuesta\"].json;\n\nreturn [{\n  json: {\n    ...respData,\n    confirmId: respData.confirmId,\n    tourCode: confData.tour_code || '',\n    fecha: confData.fecha || '',\n    productId: confData.product_id || '',\n    calendarEventId: confData.calendar_event_id || '',\n    guiaCodigo: confData.guia_codigo || '',\n    guiaNombre: confData.guia_nombre || '',\n    estado: confData.estado || '',\n    canal: confData.canal || ''\n  }\n}];"
      },
      "id": "4fb1a07b-584e-4ba3-8675-a0b6dca5448e",
      "name": "Consolidar Datos",
