    {
      "parameters": {
        "jsCode": "// El guía rechazó: buscar siguiente guía pendiente\nconst data = $node[\"Consolidar Datos\"].json;\n\n// Leer guías pendientes del evento\n// NOTA: Esto requiere leer el Sheet de Eventos para obtener la lista actualizada\n// Por ahora, notificamos al equipo para gestión manual\n// En producción: leer Sheet → sacar siguiente de la lista → llamar al WF Contactar Guía\n\nreturn [{\n  json: {\n    ...data,\n    mensajeRechazo: `❌ ${data.guiaNombre} no está disponible para ${data.tourCode} el ${data.fecha}. Contactar al siguiente guía pendiente.`\n  }\n}];"
      },
