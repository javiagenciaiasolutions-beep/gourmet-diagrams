    {
      "parameters": {
        "jsCode": "// Parsear parámetros de la URL de respuesta del guía\nconst query = $input.first().json.query || $input.first().json;\n\nconst action = query.action || ''; // 'confirm' o 'reject'\nconst confirmId = query.id || '';\n\nif (!confirmId || !action) {\n  throw new Error('Faltan parámetros: action e id son obligatorios');\n}\n\nreturn [{\n  json: {\n    action,\n    confirmId,\n    acepta: action === 'confirm',\n    timestamp: DateTime.now().setZone('Europe/Madrid').toISO()\n  }\n}];"
      },
      "id": "5d9a4e81-042c-4ace-9146-c96e35a14478",
      "name": "Parsear Respuesta",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
