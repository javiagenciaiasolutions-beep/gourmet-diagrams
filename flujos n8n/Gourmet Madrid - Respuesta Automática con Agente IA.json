    {
      "parameters": {
        "jsCode": "// Preparar datos para el Agente IA\nconst kbData = $input.first().json;\nconst emailData = $node[\"Gmail Trigger\"].json;\n\n// Extraer texto del KB\nlet kbText = '';\nif (typeof kbData === 'string') {\n  kbText = kbData;\n} else if (kbData.data) {\n  kbText = typeof kbData.data === 'string' ? kbData.data : JSON.stringify(kbData.data);\n} else if (kbData.body) {\n  kbText = typeof kbData.body === 'string' ? kbData.body : JSON.stringify(kbData.body);\n} else {\n  kbText = JSON.stringify(kbData);\n}\n\n// System prompt para el agente\nconst systemPrompt = `Eres el asistente de atención al cliente de Gourmet Madrid, un restaurante de alta cocina española en el centro de Madrid.\n\nPERSONALIDAD:\n- Profesional pero cercano y cálido\n- Siempre en español\n- Representas al restaurante con orgullo\n\nKNOWLEDGE BASE DEL RESTAURANTE:\n---\n${kbText}\n---\n\nREGLAS ESTRICTAS:\n1. Responde ÚNICAMENTE con información que esté en el Knowledge Base.\n2. Si la pregunta NO se puede responder con el KB, sé honesto: indica que vas a trasladar la consulta al equipo.\n3. SIEMPRE responde en formato JSON válido con esta estructura:\n{\"answer\": \"tu respuesta completa aquí\", \"confidence\": 85}\n- answer: respuesta profesional y completa para el cliente\n- confidence: número 0-100\n  - 80-100: La información está claramente en el KB\n  - 50-79: Información parcial, respuesta inferida\n  - 0-49: No hay información suficiente en el KB\n4. NO inventes información que no esté en el KB.\n5. Incluye detalles específicos del KB cuando sea posible (horarios, precios, etc.).`;\n\n// Mensaje del usuario (el email recibido)\nconst userMessage = `Analiza este email de un cliente y genera una respuesta:\n\nDe: ${emailData.from}\nAsunto: ${emailData.subject}\nFecha: ${emailData.date}\n\nContenido:\n${emailData.text || emailData.snippet || '(sin contenido)'}`;\n\nreturn [{\n  json: {\n    systemPrompt,\n    userMessage,\n    messageId: emailData.id,\n    threadId: emailData.threadId,\n    originalFrom: emailData.from,\n    originalSubject: emailData.subject,\n    originalDate: emailData.date,\n    originalBody: emailData.text || emailData.snippet || ''\n  }\n}];"
      },
      "id": "fa8d8656-fcb6-4106-bf7d-25e36a7fcefd",
      "name": "Preparar Consulta",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1088,
        48
      ]
    },
    {
      "parameters": {
        "text": "={{ $json.userMessage }}",
        "options": {
          "systemMessage": "={{ $json.systemPrompt }}",
          "maxIterations": 3
        }
      },
      "id": "ef5b6c2d-c198-41a3-9040-5b3d78ede6d4",
      "name": "Agente IA",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [
        -640,
        32
      ]
    },
    {
      "parameters": {
        "jsCode": "// Evaluar la respuesta del Agente IA\nconst agentResponse = $input.first().json;\nconst prevData = $node[\"Preparar Consulta\"].json;\n\nlet aiAnswer = '';\nlet confidence = 0;\n\ntry {\n  // El agente devuelve su respuesta en .output\n  const outputText = agentResponse.output || agentResponse.text || '';\n\n  // Intentar extraer JSON de la respuesta\n  const jsonMatch = outputText.match(/\\{[\\s\\S]*?\"answer\"[\\s\\S]*?\"confidence\"[\\s\\S]*?\\}/);\n\n  if (jsonMatch) {\n    const parsed = JSON.parse(jsonMatch[0]);\n    aiAnswer = parsed.answer || '';\n    confidence = typeof parsed.confidence === 'number' ? parsed.confidence : 0;\n  } else {\n    // Si no hay JSON, usar respuesta completa como answer con baja confianza\n    aiAnswer = outputText;\n    confidence = 30;\n  }\n} catch (e) {\n  // Fallback: usar texto raw del agente\n  const rawOutput = agentResponse.output || agentResponse.text || 'Error procesando la respuesta';\n  // Limpiar posibles marcadores JSON rotos\n  aiAnswer = rawOutput.replace(/[{}\"]/g, '').trim();\n  confidence = 0;\n}\n\n// Construir HTML de respuesta con firma corporativa\nconst replyHtml = `<div style=\"font-family: Georgia, serif; color: #2c2c2c; line-height: 1.6;\">\n<p>${aiAnswer.replace(/\\n/g, '<br>')}</p>\n<br>\n<hr style=\"border: none; border-top: 1px solid #c9a96e; margin: 20px 0;\">\n<p style=\"color: #8b7355; font-size: 13px;\">\n<strong>Gourmet Madrid</strong><br>\nAtención al Cliente<br>\n<a href=\"mailto:info@gourmetmadrid.com\" style=\"color: #c9a96e;\">info@gourmetmadrid.com</a>\n</p>\n</div>`;\n\nreturn [{\n  json: {\n    answer: aiAnswer,\n    confidence: confidence,\n    replyHtml: replyHtml,\n    messageId: prevData.messageId,\n    threadId: prevData.threadId,\n    originalFrom: prevData.originalFrom,\n    originalSubject: prevData.originalSubject,\n    originalDate: prevData.originalDate,\n    originalBody: prevData.originalBody\n  }\n}];"
      },
