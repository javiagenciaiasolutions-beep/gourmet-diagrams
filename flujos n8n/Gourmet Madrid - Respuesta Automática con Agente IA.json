      "parameters": {
        "sendTo": "equipo@gourmetmadrid.com",
        "subject": "=⚠️ Respuesta manual necesaria — {{ $json.originalSubject }}",
        "message": "=<div style=\"font-family: Arial, sans-serif; max-width: 600px;\">\n<div style=\"background: #e74c3c; color: white; padding: 16px 20px; border-radius: 8px 8px 0 0;\">\n<h2 style=\"margin: 0;\">⚠️ Se requiere respuesta manual</h2>\n</div>\n<div style=\"border: 1px solid #dee2e6; border-top: none; padding: 20px; border-radius: 0 0 8px 8px;\">\n<table style=\"border-collapse: collapse; width: 100%; margin-bottom: 20px;\">\n<tr><td style=\"padding: 10px 12px; font-weight: bold; background: #f8f9fa; border: 1px solid #dee2e6; width: 140px;\">De:</td><td style=\"padding: 10px 12px; border: 1px solid #dee2e6;\">{{ $json.originalFrom }}</td></tr>\n<tr><td style=\"padding: 10px 12px; font-weight: bold; background: #f8f9fa; border: 1px solid #dee2e6;\">Asunto:</td><td style=\"padding: 10px 12px; border: 1px solid #dee2e6;\">{{ $json.originalSubject }}</td></tr>\n<tr><td style=\"padding: 10px 12px; font-weight: bold; background: #f8f9fa; border: 1px solid #dee2e6;\">Fecha:</td><td style=\"padding: 10px 12px; border: 1px solid #dee2e6;\">{{ $json.originalDate }}</td></tr>\n<tr><td style=\"padding: 10px 12px; font-weight: bold; background: #f8f9fa; border: 1px solid #dee2e6;\">Confianza IA:</td><td style=\"padding: 10px 12px; border: 1px solid #dee2e6;\"><span style=\"background: #e74c3c; color: white; padding: 3px 10px; border-radius: 12px; font-weight: bold;\">{{ $json.confidence }}%</span></td></tr>\n</table>\n<h3 style=\"color: #2c3e50; border-bottom: 2px solid #3498db; padding-bottom: 8px;\">📩 Email original del cliente:</h3>\n<div style=\"background: #f8f9fa; padding: 16px; border-left: 4px solid #3498db; margin: 12px 0; white-space: pre-wrap;\">{{ $json.originalBody }}</div>\n<h3 style=\"color: #2c3e50; border-bottom: 2px solid #f39c12; padding-bottom: 8px;\">🤖 Borrador sugerido por IA:</h3>\n<div style=\"background: #fff3cd; padding: 16px; border-left: 4px solid #f39c12; margin: 12px 0;\">{{ $json.answer }}</div>\n<p style=\"color: #999; font-size: 11px; margin-top: 20px;\">Workflow automático · Gourmet Madrid · Agente IA</p>\n</div>\n</div>",
