    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst months = {\n  'january': '01', 'february': '02', 'march': '03', 'april': '04',\n  'may': '05', 'june': '06', 'july': '07', 'august': '08',\n  'september': '09', 'october': '10', 'november': '11', 'december': '12',\n  'enero': '01', 'febrero': '02', 'marzo': '03', 'abril': '04',\n  'mayo': '05', 'junio': '06', 'julio': '07', 'agosto': '08',\n  'septiembre': '09', 'octubre': '10', 'noviembre': '11', 'diciembre': '12'\n};\n\nconst monthPattern = Object.keys(months).join('|');\n\nfunction extractDate(text) {\n  // 1) Modificación: fecha ISO después de la flecha ➡ (fecha NUEVA)\n  const modMatch = text.match(/➡\\s*(\\d{4})-(\\d{2})-(\\d{2})/);\n  if (modMatch) {\n    return { year: modMatch[1], month: modMatch[2], day: modMatch[3] };\n  }\n\n  // 2) \"Event date: (Day) DD Month YYYY\" o \"Fecha del evento: (Día) DD Mes YYYY\"\n  const namedMatch = text.match(\n    new RegExp(`(?:Event date|Fecha del evento):\\\\s*\\\\([^)]+\\\\)\\\\s*(\\\\d{1,2})\\\\s+(${monthPattern})\\\\s+(\\\\d{4})`, 'i')\n  );\n  if (namedMatch) {\n    const m = months[namedMatch[2].toLowerCase()];\n    if (m) return { year: namedMatch[3], month: m, day: String(parseInt(namedMatch[1])).padStart(2, '0') };\n  }\n\n  // 3) Fallback: \"(Día) DD Mes YYYY\" sin prefijo\n  const fallback = text.match(\n    new RegExp(`\\\\([^)]+\\\\)\\\\s*(\\\\d{1,2})\\\\s+(${monthPattern})\\\\s+(\\\\d{4})`, 'i')\n  );\n  if (fallback) {\n    const m = months[fallback[2].toLowerCase()];\n    if (m) return { year: fallback[3], month: m, day: String(parseInt(fallback[1])).padStart(2, '0') };\n  }\n\n  return null;\n}\n\nconst results = [];\n\nfor (const item of items) {\n  // Prioridad: text (completo) > html (sin tags) > snippet (truncado)\n  const fullText = item.json.text \n    || (item.json.html ? item.json.html.replace(/<[^>]+>/g, ' ') : '') \n    || item.json.snippet \n    || '';\n\n  const date = extractDate(fullText);\n\n  if (!date) continue;\n\n  const labelName = `Turitop/${date.year}/${date.month}/${date.day}`;\n\n  results.push({\n    json: {\n      messageId: item.json.id,\n      labelName: labelName,\n      subject: item.json.subject || item.json.Subject,\n      from: item.json.from?.text || item.json.From,\n      date: item.json.internalDate,\n      year: date.year,\n      month: date.month,\n      day: date.day\n    }\n  });\n}\n\nif (results.length === 0) {\n  throw new Error('Ningún email del batch contenía fecha de evento válida');\n}\n\nreturn results;"
      },
