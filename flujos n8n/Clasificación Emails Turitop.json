      "parameters": {
        "jsCode": "// Buscar si la etiqueta destino ya existe\nconst items = $input.all();\nconst labelsResponse = items[0].json;\nconst extractData = $node[\"Extraer Fecha\"].json;\n\nconst targetLabel = extractData.labelName;\nconst messageId = extractData.messageId;\nconst labels = labelsResponse.labels || [];\n\n// Buscar la etiqueta exacta\nconst found = labels.find(l => l.name === targetLabel);\n\nreturn [{\n  json: {\n    labelId: found ? found.id : null,\n    labelExists: found ? true : false,\n    labelName: targetLabel,\n    messageId: messageId\n  }\n}];"
      },
