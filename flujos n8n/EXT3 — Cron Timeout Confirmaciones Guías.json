        "message": "=<div style=\"font-family:Arial,sans-serif\"><div style=\"background:#9b59b6;color:white;padding:16px;border-radius:8px 8px 0 0\"><h2 style=\"margin:0\">⏰ TIMEOUT — Guía no respondió</h2></div><div style=\"border:1px solid #ddd;padding:20px;border-radius:0 0 8px 8px\"><p><strong>{{ $json.guia_nombre }}</strong> no respondió en {{ $json.timeout_horas }}h (transcurridas: {{ $json.horasTranscurridas }}h).</p><table style=\"border-collapse:collapse;width:100%\"><tr><td style=\"padding:8px;background:#f8f9fa;border:1px solid #dee2e6;font-weight:bold\">Tour</td><td style=\"padding:8px;border:1px solid #dee2e6\">{{ $json.tour_code }}</td></tr><tr><td style=\"padding:8px;background:#f8f9fa;border:1px solid #dee2e6;font-weight:bold\">Fecha</td><td style=\"padding:8px;border:1px solid #dee2e6\">{{ $json.fecha }}</td></tr><tr><td style=\"padding:8px;background:#f8f9fa;border:1px solid #dee2e6;font-weight:bold\">Guía</td><td style=\"padding:8px;border:1px solid #dee2e6\">{{ $json.guia_nombre }} ({{ $json.guia_codigo }})</td></tr><tr><td style=\"padding:8px;background:#f8f9fa;border:1px solid #dee2e6;font-weight:bold\">Canal</td><td style=\"padding:8px;border:1px solid #dee2e6\">{{ $json.canal }}</td></tr></table><p style=\"margin-top:16px;font-weight:bold;color:#9b59b6\">⚡ Acción requerida: contactar al siguiente guía pendiente o asignar manualmente.</p></div></div>",
