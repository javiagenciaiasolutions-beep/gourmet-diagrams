      "id": "8e083d81-6893-4173-b8ce-75cd50257f25",
      "name": "Leer Pendientes",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        240,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "// Filtrar confirmaciones expiradas\nconst items = $input.all();\nconst now = DateTime.now().setZone('Europe/Madrid');\nconst expiradas = [];\n\nfor (const item of items) {\n  const data = item.json;\n  if (!data.timestamp_envio || !data.timeout_horas) continue;\n\n  const envio = DateTime.fromISO(data.timestamp_envio, { zone: 'Europe/Madrid' });\n  const timeout = parseInt(data.timeout_horas || 24);\n  const limite = envio.plus({ hours: timeout });\n\n  if (now > limite) {\n    const horasTranscurridas = Math.round(now.diff(envio, 'hours').hours);\n    expiradas.push({\n      json: {\n        ...data,\n        horasTranscurridas,\n        limiteISO: limite.toISO(),\n        expirado: true\n      }\n    });\n  }\n}\n\n// Si no hay expiradas, devolver array vacío (el IF siguiente lo detectará)\nif (expiradas.length === 0) {\n  return [{ json: { hayExpiradas: false, count: 0 } }];\n}\n\n// Devolver las expiradas\nreturn expiradas.map(e => ({\n  json: { ...e.json, hayExpiradas: true, count: expiradas.length }\n}));"
      },
      "id": "c71a10e9-bec2-402a-8e3a-314d21fd9320",
      "name": "Filtrar Expiradas",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
